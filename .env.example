# ──────────────────────────────────────────────────────────
# Copy this file to .env for local execution.
# NEVER commit .env — it is in .gitignore.
# In CI, set these as GitHub Actions secrets / env vars.
# ──────────────────────────────────────────────────────────

# Application URLs
BASE_URL=https://your-app.example.com
API_BASE_URL=https://api.your-app.example.com

# Test credentials  (stored in GitHub Secrets for CI)
TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=SuperSecret123!

# Admin credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=AdminSecret456!

# API keys / tokens
API_KEY=your-api-key-here

# Optional: Allure server (for Allure TestOps)
# ALLURE_TOKEN=
# ALLURE_PROJECT_ID=
